alternate-urgent-background: #141415;
alternate-urgent-foreground: #FBF7F5;

selected-active-background: #B38F86;
selected-active-foreground: #FBF7F5;
selected-normal-background: #B38F86;
selected-normal-foreground: #FBF7F5;
