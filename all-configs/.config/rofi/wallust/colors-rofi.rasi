 /* wallust template - colors-rofi */

* {
active-background: #65616D;
active-foreground: #FBF7F5;
normal-background: #141415;
normal-foreground: #FBF7F5;
urgent-background: #B38F86;
urgent-foreground: #FBF7F5;

alternate-active-background: #56535D;
alternate-active-foreground: #FBF7F5;
alternate-normal-background: #141415;
